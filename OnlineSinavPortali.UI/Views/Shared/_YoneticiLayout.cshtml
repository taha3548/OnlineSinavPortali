<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Yönetim Paneli</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #6c5ce7;
            --secondary-color: #fdcb6e;
            --accent-color: #00cec9;
            --text-main: #2d3436;
            --bg-color: #f8faff;
        }

        body { 
            background-color: var(--bg-color); 
            color: var(--text-main);
            font-family: 'Nunito', sans-serif;
            overflow-x: hidden;
        }

        /* Sidebar Design */
        .sidebar {
            min-height: 100vh;
            background: linear-gradient(180deg, var(--primary-color) 0%, #4834d4 100%);
            color: white;
            box-shadow: 5px 0 25px rgba(108, 92, 231, 0.2);
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
        }
        
        .sidebar-brand {
            font-weight: 800;
            font-size: 1.3rem;
            color: white;
            padding: 30px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 15px;
        }

        .sidebar a {
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            padding: 14px 25px;
            display: block;
            font-weight: 700;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            border-left: 4px solid transparent;
        }
        
        .sidebar a:hover {
            color: white;
            background-color: rgba(255,255,255,0.1);
            border-left-color: var(--secondary-color);
            transform: translateX(5px);
        }

        .sidebar a.active {
            color: white;
            background-color: rgba(255,255,255,0.2);
            border-left-color: var(--secondary-color);
        }

        /* Content Area */
        .content-area { 
            padding: 30px 40px; 
            width: 100%; 
            margin-left: 260px; /* Sidebar width */
        }

        .admin-glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.03);
            border: 1px solid rgba(255, 255, 255, 0.9);
            transition: all 0.3s;
        }
        .admin-glass-card:hover {
            box-shadow: 0 20px 40px rgba(108, 92, 231, 0.08);
            transform: translateY(-5px);
        }

        .admin-table thead {
            background: var(--primary-color);
            color: white;
        }
        .admin-table th { border-bottom: none; padding: 15px; font-weight: 800; }
        .admin-table td { padding: 15px; color: var(--text-main); font-weight: 600; border-bottom: 1px dashed #dfe6e9; }
        .admin-table tbody tr:hover { background-color: rgba(108, 92, 231, 0.05); }

    </style>
</head>
<body>
    <div class="d-flex w-100">
        <!-- Sidebar -->
        <div class="sidebar" style="width: 260px;">
            <div class="sidebar-brand text-center">
                <i class="fa-solid fa-user-astronaut text-warning mb-2 fa-2x"></i><br/>
                Yönetici Paneli
            </div>
            <ul class="list-unstyled">
                <li><a href="/Admin/Index" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"><i class="fa-solid fa-chart-pie me-2"></i> İstatistikler</a></li>
                <li><a href="/Admin/Sinavlar" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Sinavlar" ? "active" : "")"><i class="fa-solid fa-file-signature me-2"></i> Sınav Yönetimi</a></li>
                <li><a href="/Admin/Sorular" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Sorular" ? "active" : "")"><i class="fa-solid fa-circle-question me-2"></i> Soru Havuzu</a></li>
                <li><a href="/Admin/Kullanicilar" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Kullanicilar" ? "active" : "")"><i class="fa-solid fa-users me-2"></i> Kullanıcılar</a></li>
                <li><a href="/Admin/Sonuclar" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Sonuclar" ? "active" : "")"><i class="fa-solid fa-chart-column me-2"></i> Öğrenci Sonuçları</a></li>
                <li><a href="/Admin/Profil" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Profil" ? "active" : "")"><i class="fa-solid fa-user-gear me-2 text-warning"></i> Profilim</a></li>
                
                <li class="mt-4"><a href="/Home/Index" style="border-left-color: transparent;"><i class="fa-solid fa-door-open me-2"></i> Portal'a Dön</a></li>
                <li class="mt-2 px-3"><button class="btn btn-warning w-100 fw-bold rounded-pill text-dark" onclick="logOut()"><i class="fa-solid fa-power-off me-1"></i> Sistemi Kapat</button></li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="content-area">
            <nav class="navbar navbar-light bg-white rounded-pill shadow-sm mb-5 px-4 py-3 border border-light">
                <span class="navbar-brand mb-0 h4 fw-bold text-primary" id="pageTitle">
                    <i class="fa-solid fa-hashtag text-secondary me-2"></i>@ViewData["Title"]
                </span>
                <a href="/Admin/Profil" class="d-flex align-items-center bg-light px-3 py-2 rounded-pill border text-decoration-none shadow-sm hvr-grow">
                    <img id="adminAvatar" src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" 
                         class="rounded-circle me-2" style="width:30px; height:30px; border: 2px solid var(--primary-color);">
                    <span class="text-dark fw-bold" id="adminName">Yükleniyor...</span>
                </a>
            </nav>

            @RenderBody()
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/app.js"></script>
    <script>
        // JWT'den payload'ı çöze rol bilgisini doğrudan alıyoruz (localStorage'a güvenmiyoruz)
        function getTokenRole() {
            var token = getToken();
            if (!token) return null;
            try {
                var payload = JSON.parse(atob(token.split('.')[1]));
                // ASP.NET Core ClaimTypes.Role claim'i
                var roleKey = Object.keys(payload).find(k => k.toLowerCase().includes('role'));
                return roleKey ? payload[roleKey] : null;
            } catch(e) { return null; }
        }

        $(document).ready(function() {
            var gercekRol = getTokenRole();
            var user = getUser();

            // localStorage'ı token'dan gelen gerçek rolle güncelle
            if (gercekRol) {
                localStorage.setItem('userRole', gercekRol);
            }

            var yetkili = (gercekRol === 'Admin' || gercekRol === 'SiteYoneticisi');
            if (user && yetkili) {
                $("#adminName").html(
                    (gercekRol === 'SiteYoneticisi'
                        ? '<span class="badge me-2" style="background:linear-gradient(135deg,#fdcb6e,#e17055);">👑 Site Yöneticisi</span>'
                        : '<span class="badge bg-danger me-2">🛡️ Admin</span>')
                    + (user.name || '')
                );
                if(user.avatar) {
                    $("#adminAvatar").attr("src", "https://api.dicebear.com/7.x/avataaars/svg?seed=" + user.avatar);
                }
                // Sadece SiteYoneticisi ise Rol Yönetimi menüsünü göster
                if (gercekRol === 'SiteYoneticisi') {
                    $("#rolYonetimiMenu").show();
                }
            } else {
                Swal.fire('Erişim Reddedildi!', 'Sadece yöneticiler buraya girebilir.', 'error').then(() => {
                    window.location.href = '/Home/Index';
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
