@{
    Layout = "_YoneticiLayout";
    ViewData["Title"] = "Soru Havuzu";
}

<div class="admin-glass-card mb-4" style="background: rgba(108, 92, 231, 0.05);">
    <div class="row align-items-center">
        <div class="col-md-5">
            <h4 class="fw-bold text-primary mb-0"><i class="fa-solid fa-filter me-2 text-warning"></i> Hangi sınavı düzenleyeceğiz?</h4>
        </div>
        <div class="col-md-7">
            <select class="form-select border-primary text-primary fw-bold shadow-sm" id="sinavSecici" style="border-radius: 15px; height: 50px; font-size: 1.1rem;">
                <option value="">-- Lütfen bir Sınav Seçin --</option>
            </select>
        </div>
    </div>
</div>

<div class="admin-glass-card d-none" id="soruAlani">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold text-dark mb-0 fs-4" id="seciliSinavAdi"><i class="fa-solid fa-list-check text-success me-2"></i> Sınav Soruları</h5>
        <button class="btn btn-primary fw-bold px-4" style="border-radius: 30px; box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);" data-bs-toggle="modal" data-bs-target="#yeniSoruModal">
            <i class="fa-solid fa-plus me-1"></i> Yeni Soru Ekle
        </button>
    </div>
    
    <div class="table-responsive rounded overflow-hidden shadow-sm border border-light">
        <table class="table table-hover admin-table align-middle mb-0 bg-white">
            <thead style="background-color: var(--primary-color);">
                <tr>
                    <th width="45%" class="text-white pb-3 pt-3">Soru İçeriği</th>
                    <th width="40%" class="text-white pb-3 pt-3">A - B - C - D Seçenekleri</th>
                    <th width="15%" class="text-white pb-3 pt-3 text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody id="sorularTableBody">
                <tr><td colspan="3" class="text-center text-muted fw-bold py-5">Sınav soruları aranıyor...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Yeni Soru Modalı -->
<div class="modal fade" id="yeniSoruModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 shadow-lg bg-light" style="border-radius: 20px;">
      <div class="modal-header bg-primary text-white" style="border-top-left-radius: 20px; border-top-right-radius: 20px; padding: 20px;">
        <h4 class="modal-title fw-bold"><i class="fa-solid fa-circle-question text-warning me-2"></i>Yeni Soru Ekle</h4>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="soruEkleForm">
          <div class="modal-body p-4 p-md-5">
            <div class="mb-4">
                <label class="form-label fw-bold text-primary fs-5">Soru Tipi:</label>
                <select class="form-select border-primary shadow-sm fw-bold" id="SoruTipi" style="border-radius: 15px;">
                    <option value="CoktanSecmeli">Çoktan Seçmeli (4 Şık)</option>
                    <option value="DogruYanlis">Doğru / Yanlış</option>
                    <option value="BoslukDoldurma">Boşluk Doldurma (Kelime)</option>
                </select>
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold text-primary fs-5">Soru Metnini Girin:</label>
                <textarea class="form-control border-primary shadow-sm" id="SoruMetni" rows="3" required placeholder="Soru metnini yazın..." style="border-radius: 15px; font-weight:600;"></textarea>
            </div>
            <div id="dinamikSecenekAlanlari"></div>
          </div>
          <div class="modal-footer bg-white" style="border-bottom-left-radius: 20px; border-bottom-right-radius: 20px;">
            <button type="button" class="btn btn-secondary fw-bold rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
            <button type="submit" class="btn btn-primary fw-bold rounded-pill px-5"><i class="fa-solid fa-save me-1"></i> Soruyu Ekle</button>
          </div>
      </form>
    </div>
  </div>
</div>

<!-- Düzenleme Modalı -->
<div class="modal fade" id="soruDuzenleModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 shadow-lg bg-light" style="border-radius: 20px;">
      <div class="modal-header bg-warning text-dark" style="border-top-left-radius: 20px; border-top-right-radius: 20px; padding: 20px;">
        <h4 class="modal-title fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i>Soruyu Düzenle</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="soruDuzenleForm">
          <input type="hidden" id="editSoruId" />
          <input type="hidden" id="editSoruTipi" />
          <div class="modal-body p-4 p-md-5">
            <div class="mb-4">
                <label class="form-label fw-bold text-primary fs-5">Soru Metni:</label>
                <textarea class="form-control border-primary shadow-sm" id="editSoruMetni" rows="3" required style="border-radius: 15px; font-weight:600;"></textarea>
            </div>
            <div id="editDinamikSecenekAlanlari"></div>
          </div>
          <div class="modal-footer bg-white" style="border-bottom-left-radius: 20px; border-bottom-right-radius: 20px;">
            <button type="button" class="btn btn-secondary fw-bold rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
            <button type="submit" class="btn btn-warning fw-bold rounded-pill px-5 text-dark"><i class="fa-solid fa-save me-1"></i> Değişiklikleri Kaydet</button>
          </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        let mevcutSınavId = null;

        function secenekAlanlariniCiz(tip, targetDivId = "dinamikSecenekAlanlari", existingData = null) {
            let html = "";
            const prefix = targetDivId === "editDinamikSecenekAlanlari" ? "edit_" : "";
            const radioName = targetDivId === "editDinamikSecenekAlanlari" ? "editDogruCevap" : "dogruCevap";

            if(tip === "CoktanSecmeli") {
                html += `<div class="alert alert-warning border-0 rounded-4 text-dark fw-bold mb-3 small">4 şıkkı doldurun ve doğru olanı işaretleyin.</div>`;
                for(let i=0; i<4; i++) {
                    let metin = existingData && existingData[i] ? existingData[i].secenekMetni : "";
                    let isChecked = existingData && existingData[i] ? (existingData[i].dogruMu ? "checked" : "") : (i===0 ? "checked" : "");
                    html += `
                    <div class="input-group mb-2 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                        <div class="input-group-text bg-white border-primary"><input class="form-check-input" type="radio" name="${radioName}" value="${i}" ${isChecked} required></div>
                        <span class="input-group-text fw-bold text-white border-primary" style="background:var(--primary-color)">${String.fromCharCode(65+i)})</span>
                        <input type="text" class="form-control border-primary fw-bold" id="${prefix}secenek_${i}" value="${metin}" required>
                    </div>`;
                }
            } 
            else if(tip === "DogruYanlis") {
                let dChecked = existingData && existingData[0] && existingData[0].dogruMu ? "checked" : (existingData ? "" : "checked");
                let yChecked = existingData && existingData[1] && existingData[1].dogruMu ? "checked" : "";
                html += `
                <div class="row text-center mb-3">
                    <div class="col-6">
                        <label class="w-100 p-3 border border-success rounded-4 bg-light cursor-pointer shadow-sm">
                            <input class="form-check-input me-2" type="radio" name="${radioName}" value="0" ${dChecked} required>
                            <span class="fw-bold text-success">DOĞRU</span>
                        </label>
                        <input type="hidden" id="${prefix}secenek_0" value="Doğru">
                    </div>
                    <div class="col-6">
                        <label class="w-100 p-3 border border-danger rounded-4 bg-light cursor-pointer shadow-sm">
                            <input class="form-check-input me-2" type="radio" name="${radioName}" value="1" ${yChecked} required>
                            <span class="fw-bold text-danger">YANLIŞ</span>
                        </label>
                        <input type="hidden" id="${prefix}secenek_1" value="Yanlış">
                    </div>
                </div>`;
            }
            else if(tip === "BoslukDoldurma") {
                let metin = existingData && existingData[0] ? existingData[0].secenekMetni : "";
                html += `
                <div class="input-group mb-2 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                    <span class="input-group-text bg-success text-white border-success">Cevap Kelimesi:</span>
                    <input type="text" class="form-control border-success fw-bold" id="${prefix}secenek_0" value="${metin}" required>
                    <input type="hidden" name="${radioName}" value="0">
                </div>`;
            }
            $("#" + targetDivId).html(html);
        }

        $(document).ready(function() {
            secenekAlanlariniCiz("CoktanSecmeli");

            $("#SoruTipi").change(function() { secenekAlanlariniCiz($(this).val()); });

            // [AJAX ENTEGRASYONU] - Sınavları Listeleme (GET)
            ajaxRequest("/Sinavlar", "GET", null, function(res) {
                let html = `<option value="">-- Lütfen bir Sınav Seçin --</option>`;
                $.each(res, function(i, s) { html += `<option value="${s.sinavId}">${s.baslik}</option>`; });
                $("#sinavSecici").html(html);
            });

            $("#sinavSecici").change(function() {
                mevcutSınavId = $(this).val();
                if(mevcutSınavId) {
                    $("#seciliSinavAdi").html(`<i class="fa-solid fa-list-check text-success me-2"></i> ${$("#sinavSecici option:selected").text()} - Soruları`);
                    $("#soruAlani").removeClass('d-none');
                    sorulariYukle(mevcutSınavId);
                } else { $("#soruAlani").addClass('d-none'); }
            });

            // Soru Ekleme
            $("#soruEkleForm").submit(function(e) {
                e.preventDefault();
                submitSoru(false);
            });

            // Soru Düzenleme
            $("#soruDuzenleForm").submit(function(e) {
                e.preventDefault();
                submitSoru(true);
            });
        });

        function submitSoru(isEdit) {
            const formId = isEdit ? "#soruDuzenleForm" : "#soruEkleForm";
            const prefix = isEdit ? "edit_" : "";
            const radioName = isEdit ? "editDogruCevap" : "dogruCevap";
            const tip = isEdit ? $("#editSoruTipi").val() : $("#SoruTipi").val();
            const dogruIndex = parseInt($(`input[name='${radioName}']:checked`).val());

            let seceneklerData = [];
            if(tip === "CoktanSecmeli") {
                for(let i=0; i<4; i++) {
                    seceneklerData.push({ secenekMetni: $("#" + prefix + "secenek_" + i).val(), dogruMu: (dogruIndex === i) });
                }
            } else if(tip === "DogruYanlis") {
                seceneklerData = [
                    { secenekMetni: "Doğru", dogruMu: (dogruIndex === 0) },
                    { secenekMetni: "Yanlış", dogruMu: (dogruIndex === 1) }
                ];
            } else { // Bosluk
                seceneklerData = [{ secenekMetni: $("#" + prefix + "secenek_0").val(), dogruMu: true }];
            }

            let payload = {
                soruId: isEdit ? parseInt($("#editSoruId").val()) : 0,
                soruTipi: tip,
                soruMetni: isEdit ? $("#editSoruMetni").val() : $("#SoruMetni").val(),
                sinavId: parseInt(mevcutSınavId),
                secenekler: seceneklerData
            };

            const url = isEdit ? "/Sorular/" + payload.soruId : "/Sorular";
            const method = isEdit ? "PUT" : "POST";

            // [AJAX ENTEGRASYONU] - Soru Kayıt/Güncelleme (POST/PUT)
            ajaxRequest(url, method, payload, function() {
                Swal.fire({ title: 'Başarılı!', text: isEdit ? 'Soru güncellendi.' : 'Soru eklendi.', icon: 'success', timer: 1000, showConfirmButton: false });
                $(isEdit ? "#soruDuzenleModal" : "#yeniSoruModal").modal('hide');
                if(!isEdit) $(formId)[0].reset();
                sorulariYukle(mevcutSınavId);
            });
        }

        function sorulariYukle(sinavId) {
            // [AJAX ENTEGRASYONU] - Soru Filtreleme (GET)
            ajaxRequest("/Sorular/sinav/" + sinavId, "GET", null, function(res) {
                let html = "";
                $.each(res, function(i, s) {
                    let secenekStr = "<ul class='list-unstyled mb-0 small'>";
                    $.each(s.secenekler, function(j, sec) {
                        let cls = sec.dogruMu ? "text-success fw-bold" : "text-muted";
                        let icon = sec.dogruMu ? "<i class='fa fa-check-circle me-1'></i>" : "";
                        secenekStr += `<li class="${cls}">${icon}${sec.secenekMetni}</li>`;
                    });
                    secenekStr += "</ul>";

                    html += `<tr>
                        <td class="fw-bold text-dark fs-6">${s.soruMetni}</td>
                        <td>${secenekStr}</td>
                        <td class="text-end pe-3">
                            <button class="btn btn-sm btn-warning rounded-pill px-3 m-1 fw-bold" onclick="soruDuzenlePopup(${s.soruId})"><i class="fa fa-pen me-1"></i> Düzenle</button>
                            <button class="btn btn-sm btn-danger rounded-pill px-3 m-1 fw-bold" onclick="soruSil(${s.soruId})"><i class="fa fa-trash me-1"></i> Sil</button>
                        </td>
                    </tr>`;
                });
                $("#sorularTableBody").html(html || "<tr><td colspan='3' class='text-center py-4'>Soru bulunamadı.</td></tr>");
            });
        }

        window.soruDuzenlePopup = function(id) {
            ajaxRequest("/Sorular/" + id, "GET", null, function(s) {
                $("#editSoruId").val(s.soruId);
                $("#editSoruMetni").val(s.soruMetni);
                $("#editSoruTipi").val(s.soruTipi);
                secenekAlanlariniCiz(s.soruTipi, "editDinamikSecenekAlanlari", s.secenekler);
                $("#soruDuzenleModal").modal('show');
            });
        };

        window.soruSil = function(id) {
            Swal.fire({ title:'Emin misiniz?', text:'Bu soru silinecek.', icon:'warning', showCancelButton:true, confirmButtonText:'Sil' }).then((r) => {
                if(r.isConfirmed) {
                    ajaxRequest("/Sorular/" + id, "DELETE", null, function() {
                        sorulariYukle(mevcutSınavId);
                    });
                }
            });
        };
    </script>
}
