@{
    Layout = "_YoneticiLayout";
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<style>
    .nav-tabs .nav-link { font-weight: 700; border-radius: 12px 12px 0 0; color: #636e72; }
    .nav-tabs .nav-link.active { color: var(--primary-color); background: #fff; border-bottom-color: #fff; }
    .sifre-gizle { font-family: monospace; letter-spacing: 3px; color: #b2bec3; }
    .sifre-goster { font-family: monospace; color: #e17055; font-weight: 700; }
    .log-basarili { color: #00b894; }
    .log-basarisiz { color: #e17055; }
</style>

<div class="admin-glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0" style="color:var(--primary-color);">
            <i class="fa-solid fa-users-gear me-2"></i> Kullanıcı Yönetimi
        </h3>
        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary rounded-pill px-3 py-2 fs-6" id="toplamKullanici">Yükleniyor...</span>
    </div>

    <!-- Sekmeler -->
    <ul class="nav nav-tabs mb-4" id="yonetimTab">
        <li class="nav-item">
            <button class="nav-link active px-4" data-bs-toggle="tab" data-bs-target="#kullanicilarTab">
                <i class="fa fa-users me-2"></i> Kullanıcılar
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link px-4" data-bs-toggle="tab" data-bs-target="#loglarTab" onclick="loglariYukle()">
                <i class="fa fa-clock-rotate-left me-2"></i> Giriş Logları
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <!-- ===== KULLANICILAR SEKMESİ ===== -->
        <div class="tab-pane fade show active" id="kullanicilarTab">
            <div class="input-group mb-4" style="max-width:380px;">
                <span class="input-group-text bg-primary text-white border-0"><i class="fa fa-magnifying-glass"></i></span>
                <input type="text" id="aramaKutusu" class="form-control border-0 shadow-sm" placeholder="İsim veya e-posta ara..." oninput="aramaYap()">
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle" style="border-radius:12px;overflow:hidden;">
                    <thead style="background:linear-gradient(135deg,#6c5ce7,#a29bfe);color:white;">
                        <tr>
                            <th class="py-3 ps-4">#</th>
                            <th class="py-3">Kullanıcı</th>
                            <th class="py-3">E-Posta</th>
                            <th class="py-3">Şifre <i class="fa fa-eye ms-1 opacity-75"></i></th>
                            <th class="py-3">Rol</th>
                            <th class="py-3">Kayıt</th>
                            <th class="py-3 text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody id="kullaniciTablosu">
                        <tr><td colspan="7" class="text-center py-5">
                            <i class="fa fa-spinner fa-spin fa-2x text-primary mb-2"></i>
                            <p class="text-muted fw-bold mt-2">Yükleniyor...</p>
                        </td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ===== LOGLAR SEKMESİ ===== -->
        <div class="tab-pane fade" id="loglarTab">
            <div class="table-responsive">
                <table class="table table-hover align-middle" style="border-radius:12px;overflow:hidden;">
                    <thead style="background:linear-gradient(135deg,#00cec9,#55efc4);color:#2d3436;">
                        <tr>
                            <th class="py-3 ps-4">#</th>
                            <th class="py-3">Kullanıcı</th>
                            <th class="py-3">E-Posta</th>
                            <th class="py-3">Rol</th>
                            <th class="py-3 text-center">Durum</th>
                            <th class="py-3">IP Adresi</th>
                            <th class="py-3">Tarih & Saat</th>
                        </tr>
                    </thead>
                    <tbody id="logTablosu">
                        <tr><td colspan="7" class="text-center py-4 text-muted fw-bold">
                            <i class="fa fa-arrow-up me-2"></i> "Giriş Logları" sekmesine tıkladığınızda loglar yüklenir.
                        </td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Manuel Puan Atama Modalı -->
<div class="modal fade" id="puanAtamaModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius:20px;">
      <div class="modal-header bg-primary text-white" style="border-radius:20px 20px 0 0;">
        <h5 class="modal-title fw-bold"><i class="fa fa-star me-2"></i>Hızlı Puan Tanımla</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <input type="hidden" id="puanUserId" />
        <div class="mb-3">
            <label class="form-label fw-bold text-primary">Sınav Seçin</label>
            <select id="puanSinavId" class="form-select border-0 shadow-sm rounded-3">
                <option value="0">⭐ Genel Bonus Puan (Sınavsız)</option>
            </select>
            <small class="text-muted fw-bold">Bir sınav seçmezseniz puan doğrudan 'Genel Başarı'ya eklenir.</small>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold text-primary">Verilecek Puan</label>
            <input type="number" id="puanDegeri" class="form-control border-0 shadow-sm rounded-3" min="0" max="1000" value="70">
        </div>
      </div>
      <div class="modal-footer bg-light" style="border-radius:0 0 20px 20px;">
        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
        <button type="button" class="btn btn-primary rounded-pill px-4" onclick="puanKaydet()">Puanı Tanımla</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
    let tumKullanicilar = [];
    let loglarYuklendi = false;

    function getTokenRole() {
        var token = getToken();
        if (!token) return null;
        try {
            var payload = JSON.parse(atob(token.split('.')[1]));
            var roleKey = Object.keys(payload).find(k => k.toLowerCase().includes('role'));
            return roleKey ? payload[roleKey] : null;
        } catch(e) { return null; }
    }
    const user = getUser();
    const benimRolum = user ? (getTokenRole() || user.role) : null;

    $(document).ready(function() {
        kullanicilariYukle();
    });

    // [YÖNERGE UYUMLULUĞU] - AJAX ile Kullanıcı Listeleme ve Rol Yönetimi
    function kullanicilariYukle() {
        ajaxRequest("/Kullanicilar", "GET", null, function(data) {
            tumKullanicilar = data;
            tablosuCiz(data);
        }, function(err) {
            $("#kullaniciTablosu").html(`<tr><td colspan="7" class="text-center text-danger py-4 fw-bold">
                <i class="fa fa-circle-exclamation me-2"></i>Kullanıcılar yüklenemedi.</td></tr>`);
        });
    }

    function loglariYukle() {
        if (loglarYuklendi) return;
        loglarYuklendi = true;
        $("#logTablosu").html(`<tr><td colspan="7" class="text-center py-4"><i class="fa fa-spinner fa-spin fa-2x text-primary"></i></td></tr>`);
        ajaxRequest("/Kullanicilar/loglar", "GET", null, function(loglar) {
            if (loglar.length === 0) {
                $("#logTablosu").html(`<tr><td colspan="7" class="text-center py-4 text-muted fw-bold">Henüz giriş logu yok.</td></tr>`);
                return;
            }
            let html = "";
            $.each(loglar, function(i, log) {
                let durum = log.basarili
                    ? `<span class="badge bg-success rounded-pill px-3"><i class="fa fa-check me-1"></i>Başarılı</span>`
                    : `<span class="badge bg-danger rounded-pill px-3"><i class="fa fa-xmark me-1"></i>Başarısız</span>`;
                let rolBadge = log.rol === "SiteYoneticisi"
                    ? `<span class="badge rounded-pill px-2" style="background:linear-gradient(135deg,#fdcb6e,#e17055);">👑 Site Yöneticisi</span>`
                    : log.rol === "Admin"
                        ? `<span class="badge bg-danger bg-opacity-75 rounded-pill px-2">🛡️ Admin</span>`
                        : `<span class="badge bg-success bg-opacity-75 rounded-pill px-2">🎓 Öğrenci</span>`;
                let tarih = new Date(log.girisTarihi).toLocaleString('tr-TR');
                html += `<tr>
                    <td class="ps-4 text-muted fw-bold">${i+1}</td>
                    <td class="fw-bold">${log.adSoyad}</td>
                    <td class="text-secondary">${log.email}</td>
                    <td>${rolBadge}</td>
                    <td class="text-center">${durum}</td>
                    <td><code class="bg-light px-2 rounded">${log.ipAdresi}</code></td>
                    <td class="text-muted fw-bold">${tarih}</td>
                </tr>`;
            });
            $("#logTablosu").html(html);
        }, function() {
            $("#logTablosu").html(`<tr><td colspan="7" class="text-center text-danger py-4 fw-bold">Loglar yüklenemedi.</td></tr>`);
        });
    }

    function tablosuCiz(liste) {
        $("#toplamKullanici").text(liste.length + " Kullanıcı");
        if (liste.length === 0) {
            $("#kullaniciTablosu").html(`<tr><td colspan="7" class="text-center py-5 text-muted fw-bold">Kayıtlı kullanıcı yok.</td></tr>`);
            return;
        }

        let html = "";
        $.each(liste, function(i, u) {
            // Rol badge
            let rolBadge = u.rol === "SiteYoneticisi"
                ? `<span class="badge rounded-pill px-3 py-2" style="background:linear-gradient(135deg,#fdcb6e,#e17055);color:#fff;font-size:12px;">👑 Site Yöneticisi</span>`
                : u.rol === "Admin"
                    ? `<span class="badge bg-danger bg-opacity-75 rounded-pill px-3">🛡️ Admin</span>`
                    : `<span class="badge bg-success bg-opacity-75 rounded-pill px-3">🎓 Öğrenci</span>`;

            // Şifre gösterimi — varsayılan olarak maskeli, göz ikonuna tıklanınca açılır
            let sifreGercek = u.sifre && u.sifre !== "—" && u.sifre !== "••••••••" ? u.sifre : null;
            let sifreHtml = "";
            if (sifreGercek) {
                let safeId = CSS.escape(u.id);
                sifreHtml = `
                    <span class="sifre-gizle" id="sifre_${u.id}" style="font-family:monospace;color:#b2bec3;letter-spacing:3px;">••••••••</span>
                    <button class="btn btn-sm btn-link p-0 ms-1" id="btn_${u.id}"
                        onclick="sifregoster('${u.id}', this)" data-sifre="${sifreGercek}" title="Şifreyi Göster/Gizle">
                        <i class="fa fa-eye text-primary"></i>
                    </button>`;
            } else {
                sifreHtml = `<span class="text-muted small">— yok —</span>`;
            }

            // İşlem butonları
            let islemler = "";
            if (u.rol === "SiteYoneticisi") {
                islemler = `<span class="text-warning fw-bold small"><i class="fa fa-crown me-1"></i>Korumalı</span>`;
            } else {
                // Rol butonu sadece SiteYoneticisi için
                if (benimRolum === "SiteYoneticisi") {
                    if (u.rol === "Admin") {
                        islemler += `<button class="btn btn-sm btn-outline-success rounded-pill px-2 me-1" onclick="rolDegistir('${u.id}', '${u.adSoyad}', 'Ogrenci')">
                            <i class="fa fa-graduation-cap me-1"></i>Öğrenci Yap</button>`;
                    } else {
                        islemler += `<button class="btn btn-sm btn-outline-danger rounded-pill px-2 me-1" onclick="rolDegistir('${u.id}', '${u.adSoyad}', 'Admin')">
                            <i class="fa fa-shield-halved me-1"></i>Admin Yap</button>`;
                    }
                }
                // Silme: Admin→sadece öğrenci silebilir, SiteYoneticisi→herkes
                if (benimRolum === "SiteYoneticisi" || u.rol === "Ogrenci") {
                    // Puan Ver butonu sadece öğrenciler için
                    if (u.rol === "Ogrenci") {
                        islemler += `<button class="btn btn-sm btn-outline-warning rounded-pill px-2 me-1" onclick="puanAtamaModalAc('${u.id}', '${u.adSoyad}')" title="Puan Tanımla">
                            <i class="fa fa-star"></i></button>`;
                    }
                    islemler += `<button class="btn btn-sm btn-outline-danger rounded-pill px-2" onclick="kullaniciSil('${u.id}', '${u.adSoyad}')">
                        <i class="fa fa-trash"></i></button>`;
                }
            }

            let avatarStyle = u.rol === "SiteYoneticisi"
                ? "background:linear-gradient(135deg,#fdcb6e,#e17055)"
                : u.rol === "Admin"
                    ? "background:linear-gradient(135deg,#e17055,#d63031)"
                    : "background:linear-gradient(135deg,#6c5ce7,#a29bfe)";

            let kayitTarihi = u.kayitTarihi ? new Date(u.kayitTarihi).toLocaleDateString('tr-TR') : "—";

            html += `<tr>
                <td class="ps-4 text-muted fw-bold">${i+1}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                             style="width:38px;height:38px;${avatarStyle};font-size:15px;">${u.adSoyad.charAt(0).toUpperCase()}</div>
                        <span class="fw-bold text-dark">${u.adSoyad}</span>
                    </div>
                </td>
                <td class="text-secondary">${u.email}</td>
                <td>${sifreHtml}</td>
                <td>${rolBadge}</td>
                <td class="text-center">
                    <span class="badge bg-warning text-dark rounded-pill px-3 fw-bold" title="Genel Bonus Puan">
                        <i class="fa fa-star me-1 text-primary"></i>${u.bonusPuan || 0}
                    </span>
                </td>
                <td class="text-muted small fw-bold">${kayitTarihi}</td>
                <td class="text-end pe-3">${islemler}</td>
            </tr>`;
        });

        $("#kullaniciTablosu").html(html);
    }

    function sifregoster(id, btn) {
        var span = document.getElementById("sifre_" + id);
        var sifre = btn.getAttribute("data-sifre");
        var icon = btn.querySelector("i");
        if (span.style.letterSpacing === "3px" || span.style.letterSpacing === "") {
            // Şifreyi göster
            span.textContent = sifre;
            span.style.color = "#e17055";
            span.style.fontWeight = "700";
            span.style.letterSpacing = "0";
            icon.className = "fa fa-eye-slash text-danger";
        } else {
            // Maskele
            span.textContent = "••••••••";
            span.style.color = "#b2bec3";
            span.style.fontWeight = "normal";
            span.style.letterSpacing = "3px";
            icon.className = "fa fa-eye text-primary";
        }
    }

    function aramaYap() {
        let q = $("#aramaKutusu").val().toLowerCase();
        tablosuCiz(tumKullanicilar.filter(u =>
            u.adSoyad.toLowerCase().includes(q) || u.email.toLowerCase().includes(q)
        ));
    }

    function kullaniciSil(id, ad) {
        Swal.fire({
            title: `${ad} silinsin mi?`, text: "Bu işlem geri alınamaz!",
            icon: "warning", showCancelButton: true,
            confirmButtonColor: "#e17055", cancelButtonColor: "#6c5ce7",
            confirmButtonText: "Evet, Sil!", cancelButtonText: "Vazgeç"
        }).then(r => {
            if (r.isConfirmed) {
                // [YÖNERGE UYUMLULUĞU] - AJAX ile Güvenli Veri Silme (Identity)
                ajaxRequest("/Kullanicilar/" + id, "DELETE", null, function() {
                    Swal.fire({ title: "Silindi!", text: `${ad} kaldırıldı.`, icon: "success", timer: 2000, showConfirmButton: false });
                    kullanicilariYukle();
                }, function(err) {
                    Swal.fire("Hata!", err.responseJSON?.mesaj || "Silme başarısız.", "error");
                });
            }
        });
    }

    function rolDegistir(id, ad, yeniRol) {
        Swal.fire({
            title: "Rol Değiştirilsin mi?",
            html: `<b>${ad}</b> → <span class="fw-bold text-${yeniRol === "Admin" ? "danger" : "success"}">${yeniRol === "Admin" ? "🛡️ Admin" : "🎓 Öğrenci"}</span>`,
            icon: "question", showCancelButton: true,
            confirmButtonColor: yeniRol === "Admin" ? "#e17055" : "#00b894",
            cancelButtonColor: "#636e72",
            confirmButtonText: yeniRol === "Admin" ? "Admin Yap" : "Öğrenci Yap",
            cancelButtonText: "Vazgeç"
        }).then(r => {
            if (r.isConfirmed) {
                ajaxRequest("/Kullanicilar/" + id + "/rol", "PUT", { yeniRol: yeniRol }, function() {
                    Swal.fire({ title: "Güncellendi!", text: `${ad} artık ${yeniRol}.`, icon: "success", timer: 2000, showConfirmButton: false });
                    kullanicilariYukle();
                }, function(err) {
                    if (err.status === 403) {
                        Swal.fire({ title: "Yetki Yok!", html: "Bu işlem için <b>Site Yöneticisi</b> oturumu gerekiyor.<br>Çıkış yapıp tekrar giriş yapın.", icon: "error", confirmButtonText: "Çıkış Yap", confirmButtonColor: "#e17055" }).then(() => logOut());
                    } else {
                        Swal.fire("Hata!", err.responseJSON?.mesaj || "Rol güncellenemedi.", "error");
                    }
                });
            }
        });
    }

    // [YÖNERGE] Kullanıcı Listesinden Hızlı Puan Atama Mantığı
    let sinavlarYuklendi = false;
    window.puanAtamaModalAc = function(id, ad) {
        $("#puanUserId").val(id);
        $("#puanAtamaModal .modal-title").html(`<i class="fa fa-star me-2 text-warning"></i>${ad} - Puan Tanımla`);
        
        // Sınavları ilk seferde çek, sonra hafızadan kullan
        if (!sinavlarYuklendi) {
            ajaxRequest("/Sinavlar", "GET", null, function(res) {
                let options = '<option value="0">⭐ Genel Bonus Puan (Sınavsız)</option>';
                $.each(res, function(i, s) {
                    options += `<option value="${s.sinavId}">${s.baslik}</option>`;
                });
                $("#puanSinavId").html(options);
                sinavlarYuklendi = true;
                $("#puanAtamaModal").modal('show');
            });
        } else {
            $("#puanAtamaModal").modal('show');
        }
    };

    window.puanKaydet = function() {
        let userId = $("#puanUserId").val();
        let sinavId = $("#puanSinavId").val();
        let puan = $("#puanDegeri").val();

        // [YÖNERGE] Sınavsız (Bonus Puan) Mantığı
        // [YÖNERGE UYUMLULUĞU] - AJAX ile Bonus Puan Atama Operasyonu
        if (sinavId == "0") {
            ajaxRequest("/Kullanicilar/" + userId + "/bonus-puan", "PUT", {
                yeniPuan: parseInt(puan)
            }, function(res) {
                Swal.fire('Başarılı', res.mesaj, 'success');
                $("#puanAtamaModal").modal('hide');
                kullanicilariYukle(); // Listeyi yenile ki bonus kısımları güncellensin
            });
        } else {
            // [AJAX ENTEGRASYONU] - Manuel Puan Girişi (POST)
            ajaxRequest("/Sonuclar/manuel", "POST", {
                kullaniciId: userId,
                sinavId: parseInt(sinavId),
                puan: parseInt(puan)
            }, function(res) {
                Swal.fire('Başarılı', res.mesaj, 'success');
                $("#puanAtamaModal").modal('hide');
                kullanicilariYukle();
            });
        }
    };
</script>
}
