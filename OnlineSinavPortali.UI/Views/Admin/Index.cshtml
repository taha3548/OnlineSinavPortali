@{
    Layout = "_YoneticiLayout";
    ViewData["Title"] = "Admin Dashboard";
}

<!-- [YÖNERGE UYUMLULUĞU] - Yönetici Arayüzü (Admin Tier) -->
<!-- Sistem verilerinin kontrolü ve yönetimi bu katmandan (API-MVC Entegrasyonu) sağlanır. -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white shadow h-100 border-0 rounded-4">
            <div class="card-body p-4 text-center">
                <i class="fa fa-file-alt fa-2x mb-2 opacity-75"></i>
                <h6 class="card-title text-uppercase fw-bold opacity-75">Toplam Sınav</h6>
                <h2 class="display-5 fw-black mb-0" id="toplamSinav">-</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white shadow h-100 border-0 rounded-4">
            <div class="card-body p-4 text-center">
                <i class="fa fa-users fa-2x mb-2 opacity-75"></i>
                <h6 class="card-title text-uppercase fw-bold opacity-75">Kullanıcı Sayısı</h6>
                <h2 class="display-5 fw-black mb-0" id="toplamKullanici">-</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark shadow h-100 border-0 rounded-4">
            <div class="card-body p-4 text-center">
                <i class="fa fa-pen-nib fa-2x mb-2 opacity-75"></i>
                <h6 class="card-title text-uppercase fw-bold opacity-75">Sınav Yapılma Miktarı</h6>
                <h2 class="display-5 fw-black mb-0" id="toplamKatilim">-</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white shadow h-100 border-0 rounded-4">
            <div class="card-body p-4 text-center">
                <i class="fa fa-chart-line fa-2x mb-2 opacity-75"></i>
                <h6 class="card-title text-uppercase fw-bold opacity-75">Sistem Puan Ort.</h6>
                <h2 class="display-5 fw-black mb-0" id="ortalamaPuan">-</h2>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Pasta Grafiği (Başarı Durumu) -->
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold text-dark"><i class="fa-solid fa-chart-pie text-primary me-2"></i>Genel Başarı Dağılımı</h5>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <div style="height: 280px; width: 100%;">
                    <canvas id="basariChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Bar Grafiği (Sınav Ortalamaları) -->
    <div class="col-md-7">
        <div class="card shadow border-0 rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold text-dark"><i class="fa-solid fa-chart-bar text-warning me-2"></i>En Popüler 5 Sınavın Ortalaması</h5>
            </div>
            <div class="card-body">
                <div style="height: 280px; width: 100%;">
                    <canvas id="sinavlarChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            // [AJAX ENTEGRASYONU] - Dashboard İstatistiklerini Çekme (GET)
            // Yönetici paneli ana sayfasındaki tüm sayısal veriler ve grafik dataları API'den tek bir AJAX isteği ile çekilir.
            // Sayfa yenilenmeden asenkron olarak gelen bu veri seti, Chart.js kütüphanesi ile görselleştirilir.
            ajaxRequest("/Sonuclar/istatistikler", "GET", null, function(data) {
                
                // Yukarıdaki 4 Kartı Doldur
                $("#toplamSinav").text(data.genel.totalSinav);
                $("#toplamKullanici").text(data.genel.totalKullanici);
                $("#toplamKatilim").text(data.genel.toplamKatilim);
                $("#ortalamaPuan").text(data.genel.ortalamaPuan);

                // Ortak Font Ayarı
                Chart.defaults.font.family = "'Nunito', sans-serif";
                Chart.defaults.font.weight = 'bold';

                // 1. Pasta Grafiği (Pie Chart) -> Başarı Dağılımı
                const ctxPie = document.getElementById('basariChart').getContext('2d');
                new Chart(ctxPie, {
                    type: 'doughnut',
                    data: {
                        labels: ['Başarılı (70+)', 'Orta (50-69)', 'Başarısız (<50)'],
                        datasets: [{
                            data: [data.puanGrup.basarili, data.puanGrup.orta, data.puanGrup.basarisiz],
                            backgroundColor: ['#00b894', '#fdcb6e', '#d63031'],
                            borderWidth: 0,
                            hoverOffset: 10
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '65%',
                        plugins: {
                            legend: { position: 'bottom', labels: { padding: 20, font: { size: 13 } } }
                        }
                    }
                });

                // 2. Çubuk Grafiği (Bar Chart) -> Sınav Ortalamaları
                if(data.sinavBazli && data.sinavBazli.length > 0) {
                    let sinavAdlari = data.sinavBazli.map(x => x.sinavAdi.length > 15 ? x.sinavAdi.substring(0,15)+"..." : x.sinavAdi);
                    let ortalamalar = data.sinavBazli.map(x => x.ortalamaPuan);

                    const ctxBar = document.getElementById('sinavlarChart').getContext('2d');
                    new Chart(ctxBar, {
                        type: 'bar',
                        data: {
                            labels: sinavAdlari,
                            datasets: [{
                                label: 'Puan Ortalaması',
                                data: ortalamalar,
                                backgroundColor: 'rgba(108, 92, 231, 0.7)',
                                borderColor: 'rgba(108, 92, 231, 1)',
                                borderWidth: 2,
                                borderRadius: 8,
                                borderSkipped: false
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    max: 100,
                                    grid: { display: true, drawBorder: false, color: '#f1f2f6' }
                                },
                                x: { grid: { display: false } }
                            },
                            plugins: {
                                legend: { display: false }
                            }
                        }
                    });
                } else {
                    $("#sinavlarChart").parent().html('<div class="d-flex h-100 align-items-center justify-content-center text-muted fw-bold">Henüz sınav katılımı yok.</div>');
                }
            });
        });
    </script>
}
