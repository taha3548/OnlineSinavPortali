<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Online Sınav Portalı</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-color: #6c5ce7;
            --secondary-color: #fdcb6e;
            --accent-color: #00cec9;
            --text-main: #2d3436;
            --bg-color: #f8faff;
        }

        body { 
            background-color: var(--bg-color); 
            color: var(--text-main);
            font-family: 'Nunito', sans-serif;
            overflow-x: hidden;
            position: relative;
        }

        /* Animated Background Blobs */
        .bg-shapes {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            z-index: -1;
            overflow: hidden;
        }
        .shape {
            position: absolute;
            filter: blur(80px);
            opacity: 0.5;
            animation: float 20s infinite ease-in-out;
        }
        .shape-1 { background: #6c5ce7; width: 400px; height: 400px; border-radius: 50%; top: -100px; left: -100px; animation-delay: 0s; }
        .shape-2 { background: #00cec9; width: 300px; height: 300px; border-radius: 50%; bottom: -50px; right: -50px; animation-delay: -5s; }
        .shape-3 { background: #fdcb6e; width: 250px; height: 250px; border-radius: 50%; top: 40%; left: 60%; animation-delay: -10s; }

        @@keyframes float {
            0% { transform: translateY(0) scale(1); }
            50% { transform: translateY(50px) scale(1.1); }
            100% { transform: translateY(0) scale(1); }
        }

        /* EdTech Navbar */
        .ed-nav {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            padding: 15px 0;
            box-shadow: 0 10px 30px rgba(108, 92, 231, 0.05);
            border-bottom: 2px solid rgba(255,255,255,0.4);
        }
        .ed-nav .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            background: linear-gradient(45deg, var(--primary-color), var(--accent-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .ed-nav .navbar-brand i { color: var(--primary-color); -webkit-text-fill-color: var(--primary-color); }
        
        .ed-nav .nav-link {
            font-weight: 700;
            color: #636e72 !important;
            margin: 0 12px;
            position: relative;
            transition: all 0.3s;
        }
        .ed-nav .nav-link:hover { color: var(--primary-color) !important; transform: translateY(-2px); }

        /* Edutech Interactive Buttons */
        .btn-modern {
            background: linear-gradient(45deg, var(--primary-color), #a29bfe);
            color: white;
            font-weight: 700;
            border: none;
            padding: 10px 24px;
            border-radius: 30px;
            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.3);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            position: relative;
            overflow: hidden;
        }
        .btn-modern:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 12px 25px rgba(108, 92, 231, 0.4);
            color: white;
        }
        
        .btn-modern-outline {
            background: transparent;
            color: var(--primary-color);
            border: 2px solid var(--primary-color);
            font-weight: 700;
            padding: 8px 22px;
            border-radius: 30px;
            transition: all 0.3s;
        }
        .btn-modern-outline:hover {
            background: var(--primary-color);
            color: white;
            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.3);
        }

        /* Soft Glass Cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(10px);
            border: 2px solid rgba(255, 255, 255, 0.8);
            border-radius: 25px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.05);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            padding: 30px;
        }
        .glass-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 25px 45px rgba(0,0,0,0.1);
            border-color: rgba(255, 255, 255, 1);
        }

        /* Inputs */
        .form-control {
            border-radius: 15px;
            padding: 14px 20px;
            font-weight: 600;
            border: 2px solid #dfe6e9;
            background: rgba(255,255,255,0.8);
            transition: all 0.3s;
        }
        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 5px rgba(108, 92, 231, 0.15);
            background: #fff;
            transform: scale(1.02);
        }

        footer { font-weight: 600; color: #b2bec3; }

    </style>
</head>
<body>
    <div class="bg-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>

    <nav class="navbar navbar-expand-lg ed-nav">
        <div class="container">
                <i class="fa-solid fa-graduation-cap bounce-icon"></i> Online Sınav Portalı

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-label="Menüyü aç veya kapat">
                <span class="fa fa-bars text-primary fs-3"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Index"><i class="fa-solid fa-book-open"></i> Aktif Sınavlar</a>

                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Leaderboard"><i class="fa-solid fa-trophy text-warning"></i> Liderlik Tablosu</a>

                    </li>
                    <li class="nav-item" id="myResultsLink" style="display:none;">
                        <a class="nav-link" href="/Student/MyResults"><i class="fa-solid fa-medal"></i> Sonuçlarım / Karne</a>

                    </li>
                </ul>
                <ul class="navbar-nav align-items-center" id="authNavArea">
                    <!-- Dynamic Content -->
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5" style="min-height: 70vh;">
        @RenderBody()
    </div>

    <footer class="text-center pb-4 pt-2 mt-5 border-top border-light">
        <div class="container d-flex flex-column align-items-center">
            <i class="fa-solid fa-rocket fs-3 text-primary mb-2" style="opacity: 0.5;"></i>
            <p class="mb-0">Eğlenceli ve Benzersiz Bir Sınav Deneyimi</p>

        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        window.__API_BASE_URL__ = @System.Text.Json.JsonSerializer.Serialize(Configuration["ApiBaseUrl"] ?? "https://localhost:7087/api");
    </script>
    <script src="~/js/app.js"></script>
    <script>
        $(document).ready(function() {
            var user = getUser();
            if (user && user.name) {
                $("#myResultsLink").show();
                var html = "";
                
                if(user.role === 'Admin' || user.role === 'SiteAdministrator') {
                    html += `<li class="nav-item me-2">
                        <a href="/Admin/Index" class="btn fw-bold rounded-pill px-3 py-2 text-white" 
                           style="background:linear-gradient(135deg,#6c5ce7,#a29bfe);font-size:14px;">
                           <i class="fa-solid fa-crown me-1"></i> Yönetici Paneli
                        </a>
                    </li>`;
                }

                html += `
                    <li class="nav-item dropdown ms-lg-3">
                        <a class="nav-link dropdown-toggle d-flex align-items-center bg-white px-3 py-1 rounded-pill shadow-sm border border-primary" 
                           href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="opacity:0.9">
                            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=${user.avatar || 'Felix'}" 
                                 class="rounded-circle me-2" style="width:30px; height:30px; border: 2px solid var(--primary-color);">
                            <span class="text-primary fw-bold" style="font-size:14px;">${user.name}</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-4 mt-2" aria-labelledby="userDropdown">
                            <li><a class="dropdown-item fw-bold text-dark py-2" href="/Student/Profile"><i class="fa-solid fa-user-gear me-2 text-primary"></i>Profilim</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><button class="dropdown-item fw-bold text-danger py-2" onclick="logOut()"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i>Çıkış Yap</button></li>
                        </ul>
                    </li>`;
                
                $("#authNavArea").html(html);
            } else {
                $("#authNavArea").html(`
                    <li class="nav-item"><a class="btn-modern-outline me-2" href="/Account/Login">Giriş Yap</a></li>
                    <li class="nav-item"><a class="btn-modern shadow" href="/Account/Register">Kayıt Ol 🚀</a></li>

                `);
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
