@{
    Layout = "_YoneticiLayout";
    ViewData["Title"] = "Sınav Yönetimi";

}

<div class="admin-glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary mb-0"><i class="fa-solid fa-file-signature me-2"></i> Sınavlar</h3>
        <button class="btn btn-primary fw-bold px-4" style="border-radius: 30px; box-shadow: 0 5px 15px rgba(108, 92, 231, 0.3);" data-bs-toggle="modal" data-bs-target="#newExamModal">
            <i class="fa-solid fa-plus me-1"></i> Yeni Sınav
        </button>
    </div>
    
    <div class="table-responsive rounded overflow-hidden shadow-sm">
        <table class="table table-hover admin-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Sınav Adı</th>
                    <th>Açıklama</th>
                    <th>Süre (Dak)</th>
                    <th>Geçme Notu</th>
                    <th>Toplam Puan</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody id="examsTableBody">
                <tr>
                    <td colspan="6" class="text-center text-muted fw-bold py-5">
                        <i class="fa-solid fa-spinner fa-spin fa-2x mb-3 text-primary"></i><br/>
                        Sınavlar veritabanından getiriliyor...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- New Exam Modal -->
<div class="modal fade" id="newExamModal" tabindex="-1" aria-labelledby="newExamModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
      <div class="modal-header bg-primary text-white" style="border-top-left-radius: 20px; border-top-right-radius: 20px;">
        <h5 class="modal-title fw-bold" id="newExamModalLabel"><i class="fa-solid fa-plus-circle me-2"></i>Yeni Sınav Oluştur</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
      </div>
      <form id="addExamForm">
          <div class="modal-body p-4">
            <div class="mb-3">
                <label class="form-label fw-bold text-primary">Sınav Başlığı</label>
                <input type="text" class="form-control" id="Title" required placeholder="Örn: 2026 Matematik Vize" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold text-primary">Kısa Açıklama</label>
                <textarea class="form-control" id="Description" rows="2" placeholder="Örn: Sadece ilk 4 ünite dahildir."></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold text-primary">Süre (Dakika)</label>
                <input type="number" class="form-control" id="DurationMinutes" required min="1" max="300" placeholder="Örn: 45" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold text-primary">Geçme Notu (%)</label>
                <input type="number" class="form-control" id="PassingGrade" required min="0" max="100" value="60" placeholder="Örn: 60" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold text-primary">Toplam Sınav Puanı</label>
                <input type="number" class="form-control" id="TotalScore" required min="1" value="100" placeholder="Örn: 100" />
                <small class="text-muted fw-bold">Sınavın kaç puan üzerinden değerlendirileceği.</small>
            </div>
          </div>
          <div class="modal-footer bg-light" style="border-bottom-left-radius: 20px; border-bottom-right-radius: 20px;">
            <button type="button" class="btn btn-secondary fw-bold rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
            <button type="submit" class="btn btn-primary fw-bold rounded-pill px-4"><i class="fa-solid fa-save me-1"></i> Kaydet</button>
          </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Exam Modal -->
<div class="modal fade" id="editExamModal" tabindex="-1" aria-labelledby="editExamModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
      <div class="modal-header bg-warning text-dark" style="border-top-left-radius: 20px; border-top-right-radius: 20px;">
        <h5 class="modal-title fw-bold" id="editExamModalLabel"><i class="fa-solid fa-pen-to-square me-2"></i>Sınavı Düzenle</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
      </div>
      <form id="editExamForm">
          <input type="hidden" id="editExamId" />
          <div class="modal-body p-4">
            <div class="mb-3">
                <label class="form-label fw-bold text-primary">Sınav Başlığı</label>
                <input type="text" class="form-control" id="editTitle" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold text-primary">Kısa Açıklama</label>
                <textarea class="form-control" id="editDescription" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold text-primary">Süre (Dakika)</label>
                <input type="number" class="form-control" id="editDurationMinutes" required min="1" max="300" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold text-primary">Geçme Notu (%)</label>
                <input type="number" class="form-control" id="editPassingGrade" required min="0" max="100" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold text-primary">Toplam Sınav Puanı</label>
                <input type="number" class="form-control" id="editTotalScore" required min="1" />
            </div>
          </div>
          <div class="modal-footer bg-light" style="border-bottom-left-radius: 20px; border-bottom-right-radius: 20px;">
            <button type="button" class="btn btn-secondary fw-bold rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
            <button type="submit" class="btn btn-warning fw-bold rounded-pill px-4 text-dark"><i class="fa-solid fa-save me-1"></i> Güncelle</button>
          </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadExams();

            // Exam Addition Submit Operation
            $("#addExamForm").submit(function(e) {
                e.preventDefault();
                let data = {
                    title: $("#Title").val(),
                    description: $("#Description").val(),
                    durationMinutes: parseInt($("#DurationMinutes").val()),
                    passingGrade: parseInt($("#PassingGrade").val()),
                    totalScore: parseInt($("#TotalScore").val())
                };

                let submitBtn = $(this).find('button[type="submit"]');
                submitBtn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor...');


                // [AJAX INTEGRATION] - Exam Registration (POST)
                ajaxRequest("/Exams", "POST", data, function(res) {
                    Swal.fire({
                        title: 'Başarılı!', text: 'Sınav başarıyla oluşturuldu.', icon: 'success',
                        timer: 1500, showConfirmButton: false
                    });
                    $("#newExamModal").modal('hide');
                    $("#addExamForm")[0].reset();
                    submitBtn.prop('disabled', false).html('<i class="fa-solid fa-save me-1"></i> Kaydet');
                    loadExams(); // Refresh list
                }, function(err) {
                    Swal.fire('Hata', 'Sınav kaydedilemedi: ' + (err.statusText || 'bilinmeyen'), 'error');
                    submitBtn.prop('disabled', false).html('<i class="fa-solid fa-save me-1"></i> Kaydet');

                });
            });

            // Exam Edit Submit Operation
            $("#editExamForm").submit(function(e) {
                e.preventDefault();
                let id = $("#editExamId").val();
                let data = {
                    examId: parseInt(id),
                    title: $("#editTitle").val(),
                    description: $("#editDescription").val(),
                    durationMinutes: parseInt($("#editDurationMinutes").val()),
                    passingGrade: parseInt($("#editPassingGrade").val()),
                    totalScore: parseInt($("#editTotalScore").val())
                };

                let submitBtn = $(this).find('button[type="submit"]');
                submitBtn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Güncelleniyor...');


                ajaxRequest("/Exams/" + id, "PUT", data, function(res) {
                    Swal.fire({
                        title: 'Güncellendi!', text: 'Sınav başarıyla güncellendi.', icon: 'success',
                        timer: 1500, showConfirmButton: false
                    });
                    $("#editExamModal").modal('hide');
                    submitBtn.prop('disabled', false).html('<i class="fa-solid fa-save me-1"></i> Güncelle');
                    loadExams();
                }, function(err) {
                    Swal.fire('Hata', 'Güncelleme başarısız: ' + (err.statusText || 'bilinmeyen'), 'error');
                    submitBtn.prop('disabled', false).html('<i class="fa-solid fa-save me-1"></i> Güncelle');

                });
            });
        });

        // [AJAX INTEGRATION] - Listing Exams (GET)
        function loadExams() {
            ajaxRequest("/Exams", "GET", null, function(res) {
                let html = "";
                if(res.length === 0){
                    html = `<tr><td colspan="6" class="text-center fw-bold py-4 text-muted">Kayıtlı sınav bulunamadı. Sağ üstten yeni bir sınav oluşturun.</td></tr>`;

                } else {
                    $.each(res, function(i, s) {
                        html += `
                        <tr>
                            <td class="fw-bold text-primary fs-5"><i class="fa-regular fa-file-lines text-secondary me-2"></i> ${s.title}</td>
                            <td class="text-muted fw-bold">${s.description || ''}</td>
                            <td><span class="badge bg-warning text-dark px-3 py-2 fs-6 rounded-pill"><i class="fa-solid fa-stopwatch me-1"></i> ${s.durationMinutes} Dak</span></td>
                            <td><span class="badge bg-info text-white px-3 py-2 fs-6 rounded-pill"><i class="fa-solid fa-percent me-1"></i> %${s.passingGrade}</span></td>
                            <td><span class="badge bg-success text-white px-3 py-2 fs-6 rounded-pill"><i class="fa-solid fa-star me-1"></i> ${s.totalScore} Puan</span></td>
                            <td>
                                <button class="btn btn-sm btn-warning rounded-pill px-3 m-1 fw-bold" onclick="getEditExam(${s.examId}, '${s.title.replace(/'/g, "\\'")}', '${s.description ? s.description.replace(/'/g, "\\'") : ''}', ${s.durationMinutes}, ${s.passingGrade}, ${s.totalScore})"><i class="fa-solid fa-pen me-1"></i> Düzenle</button>
                                <button class="btn btn-sm btn-danger rounded-pill px-3 m-1 fw-bold" onclick="deleteExam(${s.examId})"><i class="fa-solid fa-trash-can me-1"></i> Sil</button>
                            </td>
                        </tr>`;
                    });
                }
                $("#examsTableBody").html(html);
            });
        }

        // Open Edit Modal and Fill Data
        window.getEditExam = function(id, title, description, duration, passing, totalScore) {
            $("#editExamId").val(id);
            $("#editTitle").val(title);
            $("#editDescription").val(description);
            $("#editDurationMinutes").val(duration);
            $("#editPassingGrade").val(passing);
            $("#editTotalScore").val(totalScore || 100);
            $("#editExamModal").modal('show');
        };

        // Exam Deletion Function
        window.deleteExam = function(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu sınavı ve içindeki TÜM soruları kalıcı olarak sileceksiniz!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) {
                    ajaxRequest("/Exams/" + id, "DELETE", null, function(res) {
                        Swal.fire('Silindi!', 'Sınav başarıyla veritabanından kaldırıldı.', 'success');
                        loadExams();
                    }, function(err) {
                        Swal.fire('Hata', 'Silme sırasında bir hata oluştu.', 'error');
                    });
                }
            });
        };
    </script>
}

