@{
    Layout = "_YoneticiLayout";
    ViewData["Title"] = "Rol Yönetimi";

}

<div class="admin-glass-card">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h3 class="fw-bold mb-0" style="color:var(--primary-color);">
            <i class="fa-solid fa-user-shield me-2"></i> 👑 Rol Yönetimi
        </h3>
        <span class="badge rounded-pill px-3 py-2 fs-6" style="background:linear-gradient(135deg,#fdcb6e,#e17055);color:#fff;" id="totalUserCount">Yükleniyor...</span>

    </div>
    <p class="text-muted fw-bold mb-4">Bu paneli yalnızca <strong>Site Yöneticisi</strong> kullanabilir. Bir öğrenciyi Yönetici yapabilir veya bir Yöneticiyi Öğrenci rolüne düşürebilirsiniz.</p>


    <div id="authorityWarning" class="d-none">
        <div class="alert alert-danger border-danger border-2 rounded-4 py-4 text-center shadow-sm">
            <i class="fa-solid fa-lock fa-3x text-danger mb-3 d-block"></i>
            <h4 class="fw-bold">Erişim Engellendi!</h4>
            <p class="fw-bold mb-3">Bu sayfa yalnızca <strong>Site Yöneticisi</strong> yetkisiyle kullanılabilir.</p>
            <p class="text-muted mb-4">Token'ınız eski rolünüzü taşıyor olabilir. Çıkış yapıp tekrar girmeniz gerekebilir.</p>
            <button class="btn btn-danger btn-lg rounded-pill px-5 fw-bold" onclick="logOut()">
                <i class="fa-solid fa-right-from-bracket me-2"></i> Çıkış Yap ve Tekrar Gir
            </button>
        </div>
    </div>

    <!-- Table -->
    <div class="table-responsive" id="tableArea">
        <table class="table table-hover align-middle" style="border-radius:12px;overflow:hidden;">
            <thead style="background:linear-gradient(135deg,#fdcb6e,#e17055);color:white;">
                <tr>
                    <th class="py-3 ps-4">#</th>
                    <th class="py-3">Kullanıcı</th>
                    <th class="py-3">E-posta</th>
                    <th class="py-3">Mevcut Rol</th>
                    <th class="py-3 text-center">Rolü Değiştir</th>
                </tr>
            </thead>
            <tbody id="roleTableBody">
                <tr>
                    <td colspan="5" class="text-center py-5">
                        <i class="fa-solid fa-spinner fa-spin fa-2x text-primary mb-2"></i>
                        <p class="text-muted fw-bold mt-2">Kullanıcılar yükleniyor...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    // Get real role from JWT (localStorage might be stale)
    function getTokenRole() {
        var token = getToken();
        if (!token) return null;
        try {
            var payload = JSON.parse(atob(token.split('.')[1]));
            var roleKey = Object.keys(payload).find(k => k.toLowerCase().includes('role'));
            return roleKey ? payload[roleKey] : null;
        } catch(e) { return null; }
    }

    $(document).ready(function() {
        loadUsers();
    });

    function loadUsers() {
        ajaxRequest("/Users", "GET", null, function(data) {
            // Users fetched, draw table
            drawTable(data);
        }, function(err) {
            if (err.status === 403 || err.status === 401) {
                // No authority → show warning, hide table
                $("#tableArea").addClass("d-none");
                $("#authorityWarning").removeClass("d-none");
                $("#totalUserCount").text("Yetki Yok");
            } else {
                $("#roleTableBody").html(`<tr><td colspan="5" class="text-center text-danger py-4 fw-bold">
                    <i class="fa fa-circle-exclamation me-2"></i>Bağlantı hatası. API çalışıyor mu?</td></tr>`);
            }
        });
    }

    function drawTable(list) {
        // Exclude SiteAdministrator from list — they cannot be modified
        var filtered = list.filter(u => u.role !== "SiteAdministrator");
        $("#totalUserCount").text(filtered.length + " Kullanıcı");

        if (filtered.length === 0) {
            $("#roleTableBody").html(`<tr><td colspan="5" class="text-center py-5 text-muted fw-bold">Yönetilebilir kullanıcı bulunamadı.</td></tr>`);
            return;
        }

        let html = "";
        $.each(filtered, function(i, u) {
            let roleBadge = u.role === "Admin"
                ? `<span class="badge bg-danger bg-opacity-75 rounded-pill px-3"><i class="fa fa-shield-halved me-1"></i>Yönetici</span>`
                : `<span class="badge bg-success bg-opacity-75 rounded-pill px-3"><i class="fa fa-graduation-cap me-1"></i>Öğrenci</span>`;

            // Role change button
            let roleBtn = "";
            if (u.role === "Admin") {
                roleBtn = `<button class="btn btn-outline-success rounded-pill px-3 fw-bold" onclick="changeRole('${u.id}', '${u.fullName}', 'Student')">
                            <i class="fa fa-graduation-cap me-1"></i> Öğrenci Yap
                          </button>`;
            } else {
                roleBtn = `<button class="btn btn-outline-danger rounded-pill px-3 fw-bold" onclick="changeRole('${u.id}', '${u.fullName}', 'Admin')">
                            <i class="fa fa-shield-halved me-1"></i> Yönetici Yap
                          </button>`;
            }

            let avatarStyle = u.role === "Admin"
                ? "background:linear-gradient(135deg,#e17055,#d63031)"
                : "background:linear-gradient(135deg,#6c5ce7,#a29bfe)";

            html += `
            <tr>
                <td class="ps-4 text-muted fw-bold">${i + 1}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                             style="width:38px;height:38px;${avatarStyle};font-size:15px;">
                            ${u.fullName.charAt(0).toUpperCase()}
                        </div>
                        <span class="fw-bold text-dark">${u.fullName}</span>
                    </div>
                </td>
                <td class="text-secondary">${u.email}</td>
                <td>${roleBadge}</td>
                <td class="text-center">${roleBtn}</td>
            </tr>`;
        });

        $("#roleTableBody").html(html);
    }

    function changeRole(id, name, newRole) {
        let msg = newRole === "Admin"
            ? `<b>${name}</b> isimli kullanıcı <span class='text-danger fw-bold'>Yönetici</span> yapılacak. Sınav ve kullanıcı yönetimine erişimi olacaktır.`
            : `<b>${name}</b> isimli kullanıcı <span class='text-success fw-bold'>Öğrenci</span> rolüne düşürülecek. Yönetim paneli erişimi kaldırılacaktır.`;

        Swal.fire({
            title: "Rol Değiştirilsin mi?",
            html: msg,
            icon: "question",
            showCancelButton: true,
            confirmButtonColor: newRole === "Admin" ? "#e17055" : "#00b894",
            cancelButtonColor: "#636e72",
            confirmButtonText: newRole === "Admin" ? "✅ Yönetici Yap" : "⬇️ Öğrenci Yap",
            cancelButtonText: "İptal"
        }).then((result) => {
            if (result.isConfirmed) {
                ajaxRequest("/Users/" + id + "/role", "PUT", { newRole: newRole }, function() {
                    Swal.fire({
                        title: "Rol Güncellendi!",
                        text: `${name} artık bir ${newRole === "Admin" ? "Yönetici" : "Öğrenci"}.`,
                        icon: "success",
                        timer: 2000,
                        showConfirmButton: false
                    });
                    loadUsers();
                }, function(err) {
                    if (err.status === 403) {
                        Swal.fire({
                            title: "Yetki Yok!",
                            html: "Bu işlem için Site Yöneticisi girişi gereklidir.<br><br>Lütfen çıkış yapıp tekrar girin.",
                            icon: "error",
                            confirmButtonText: "Çıkış Yap",
                            confirmButtonColor: "#e17055"
                        }).then(() => logOut());
                    } else {
                        Swal.fire("Hata!", err.responseJSON?.message || "Rol güncellenemedi.", "error");
                    }
                });
            }
        });
    }
</script>
}
