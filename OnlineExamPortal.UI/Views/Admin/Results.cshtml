@{
    Layout = "_YoneticiLayout";
    ViewData["Title"] = "Öğrenci Sonuçları";

}

<style>
    .puan-cember {
        width: 52px; height: 52px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 900; font-size: 15px; color: white;
    }
    .filtre-btn.aktif { background: var(--primary-color); color: white; }
</style>

<div class="admin-glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h3 class="fw-bold mb-0" style="color:var(--primary-color);">
            <i class="fa-solid fa-chart-column me-2"></i> Öğrenci Sınav Sonuçları
        </h3>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary rounded-pill px-3 py-2 fs-6" id="totalResultCount">Yükleniyor...</span>
            <button class="btn btn-sm btn-outline-success rounded-pill px-3" onclick="exportCSV()">
                <i class="fa fa-file-excel me-1"></i> CSV İndir
            </button>
        </div>
    </div>

    <!-- Filters -->
    <div class="d-flex gap-2 flex-wrap mb-4">
        <input type="text" id="searchInput" class="form-control border-0 shadow-sm rounded-pill px-4" 
               style="max-width:280px;" placeholder="🔍 Öğrenci veya sınav ara..." oninput="filterResults()">
        <select id="examFilter" class="form-select border-0 shadow-sm rounded-pill" style="max-width:220px;" onchange="filterResults()">
            <option value="">📋 Tüm Sınavlar</option>
        </select>
        <select id="sortOrder" class="form-select border-0 shadow-sm rounded-pill" style="max-width:200px;" onchange="filterResults()">
            <option value="date">🕐 En Yeni</option>
            <option value="score_desc">🏆 En Yüksek Puan</option>
            <option value="score_asc">📉 En Düşük Puan</option>
        </select>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-3 mb-4" id="statistics">
        <div class="col-md-3">
            <div class="p-3 rounded-4 text-center shadow-sm" style="background:linear-gradient(135deg,#6c5ce7,#a29bfe);">
                <div class="text-white fw-bold fs-4" id="stat-total">—</div>
                <div class="text-white opacity-75 small fw-bold">Toplam Çözüm</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 rounded-4 text-center shadow-sm" style="background:linear-gradient(135deg,#00b894,#55efc4);">
                <div class="text-white fw-bold fs-4" id="stat-avg">—</div>
                <div class="text-white opacity-75 small fw-bold">Ortalama Puan</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 rounded-4 text-center shadow-sm" style="background:linear-gradient(135deg,#fdcb6e,#e17055);">
                <div class="text-white fw-bold fs-4" id="stat-highest">—</div>
                <div class="text-white opacity-75 small fw-bold">En Yüksek Puan</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 rounded-4 text-center shadow-sm" style="background:linear-gradient(135deg,#fd79a8,#e84393);">
                <div class="text-white fw-bold fs-4" id="stat-participants">—</div>
                <div class="text-white opacity-75 small fw-bold">Katılımcı Sayısı</div>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="table-responsive">
        <table class="table table-hover align-middle" style="border-radius:12px;overflow:hidden;">
            <thead style="background:linear-gradient(135deg,#6c5ce7,#a29bfe);color:white;">
                <tr>
                    <th class="py-3 ps-4">#</th>
                    <th class="py-3">Öğrenci</th>
                    <th class="py-3">Sınav</th>
                    <th class="py-3 text-center">Puan</th>
                    <th class="py-3 text-center">✅ Doğru</th>
                    <th class="py-3 text-center">❌ Yanlış</th>
                    <th class="py-3 text-center">Başarı</th>
                    <th class="py-3">Tarih</th>
                    <th class="py-3">İşlemler</th>
                </tr>
            </thead>
            <tbody id="resultsTableBody">
                <tr><td colspan="9" class="text-center py-5">
                    <i class="fa fa-spinner fa-spin fa-2x text-primary mb-2"></i>
                    <p class="text-muted fw-bold mt-2">Sonuçlar yükleniyor...</p>
                </td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    let allResults = [];

    $(document).ready(function() {
        loadResults();
    });

    // AJAX fetching and Statistics Management
    function loadResults() {
        ajaxRequest("/Results/all", "GET", null, function(data) {
            allResults = data;
            updateStatistics(data);
            fillExamFilter(data);
            drawResultsTable(data);
        }, function(err) {
            $("#resultsTableBody").html(`<tr><td colspan="9" class="text-center text-danger py-4 fw-bold">
                <i class="fa fa-circle-exclamation me-2"></i>Sonuçlar yüklenemedi.</td></tr>`);
        });
    }

    function updateStatistics(list) {
        $("#totalResultCount").text(list.length + " Sonuç");
        $("#stat-total").text(list.length);
        if (list.length > 0) {
            let avg = Math.round(list.reduce((a, b) => a + b.score, 0) / list.length);
            let highest = Math.max(...list.map(s => s.score));
            let uniqueStudents = new Set(list.map(s => s.userEmail)).size;
            $("#stat-avg").text(avg + " Puan");
            $("#stat-highest").text(highest + " Puan");
            $("#stat-participants").text(uniqueStudents + " Kişi");
        }
    }

    function fillExamFilter(list) {
        let exams = [...new Set(list.map(s => s.examTitle))];
        let options = '<option value="">📋 Tüm Sınavlar</option>';
        exams.forEach(s => options += `<option value="${s}">${s}</option>`);
        $("#examFilter").html(options);
    }

    function filterResults() {
        let q = $("#searchInput").val().toLowerCase();
        let examSec = $("#examFilter").val();
        let sortOrder = $("#sortOrder").val();

        let filtered = allResults.filter(s => {
            let searchMatch = s.userName.toLowerCase().includes(q) 
                           || s.userEmail.toLowerCase().includes(q)
                           || s.examTitle.toLowerCase().includes(q);
            let examMatch = !examSec || s.examTitle === examSec;
            return searchMatch && examMatch;
        });

        if (sortOrder === "score_desc") filtered.sort((a, b) => b.score - a.score);
        else if (sortOrder === "score_asc") filtered.sort((a, b) => a.score - b.score);

        updateStatistics(filtered);
        drawResultsTable(filtered);
    }

    function drawResultsTable(list) {
        if (list.length === 0) {
            $("#resultsTableBody").html(`<tr><td colspan="9" class="text-center py-5 text-muted fw-bold">
                <i class="fa fa-inbox fa-2x mb-2 d-block"></i>Sonuç bulunamadı.</td></tr>`);
            return;
        }

        let html = "";
        $.each(list, function(i, s) {
            let total = s.correctCount + s.wrongCount;
            let percent = total > 0 ? Math.round((s.correctCount / total) * 100) : 0;

            let scoreColor = s.score >= 85 ? "#00b894" : s.score >= 60 ? "#fdcb6e" : "#e17055";
            let successColor = percent >= 60 ? "success" : percent >= 45 ? "warning" : "danger";
            let date = new Date(s.participationDate).toLocaleString('tr-TR');

            html += `<tr>
                <td class="ps-4 text-muted fw-bold">${i+1}</td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                             style="width:36px;height:36px;background:linear-gradient(135deg,#6c5ce7,#a29bfe);font-size:14px;">
                            ${s.userName.charAt(0).toUpperCase()}
                        </div>
                        <div>
                            <div class="fw-bold text-dark" style="font-size:14px;">${s.userName}</div>
                            <div class="text-muted" style="font-size:12px;">${s.userEmail}</div>
                        </div>
                    </div>
                </td>
                <td>
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 fw-bold">
                        <i class="fa fa-file-signature me-1"></i>${s.examTitle}
                    </span>
                </td>
                <td class="text-center">
                    <div class="puan-cember mx-auto" style="background:${scoreColor};">${s.score}</div>
                </td>
                <td class="text-center">
                    <span class="badge bg-success rounded-pill px-3 fs-6">${s.correctCount}</span>
                </td>
                <td class="text-center">
                    <span class="badge bg-danger rounded-pill px-3 fs-6">${s.wrongCount}</span>
                </td>
                <td class="text-center">
                    <div class="progress" style="height:8px;border-radius:10px;min-width:80px;">
                        <div class="progress-bar bg-${successColor}" style="width:${percent}%"></div>
                    </div>
                    <small class="text-muted fw-bold">%${percent}</small>
                </td>
                <td class="text-muted small fw-bold">${date}</td>
                <td>
                    <div class="d-flex gap-1">
                        <button class="btn btn-sm btn-warning rounded-pill px-3 fw-bold" onclick="updateScore(${s.resultId}, ${s.score})" title="Puanı Güncelle">
                            <i class="fa fa-edit"></i>
                        </button>
                        <button class="btn btn-sm btn-danger rounded-pill px-3 fw-bold" onclick="resetResult(${s.resultId}, '${s.userName.replace(/'/g, "\\'")}')" title="Sınavı Sıfırla">
                            <i class="fa fa-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>`;
        });

        $("#resultsTableBody").html(html);
    }

    function exportCSV() {
        let rows = [["#","Öğrenci","Eposta","Sınav","Puan","Doğru","Yanlış","Tarih"]];
        allResults.forEach((s, i) => {
            let name = `"${s.userName}"`;
            let email = `"${s.userEmail}"`;
            let exam = `"${s.examTitle}"`;
            let date = `"${new Date(s.participationDate).toLocaleString('tr-TR')}"`;
            rows.push([i+1, name, email, exam, s.score, s.correctCount, s.wrongCount, date]);
        });
        
        let csv = rows.map(r => r.join(";")).join("\n");
        let blob = new Blob(["\uFEFF" + csv], {type: "text/csv;charset=utf-8;"});
        let url = URL.createObjectURL(blob);
        let a = document.createElement("a");
        a.href = url; a.download = "sinav_sonuclari.csv"; a.click();
    }

    // Admin Authority: Reset Exam Result (Allows student to retake)
    window.resetResult = function(id, name) {
        Swal.fire({
            title: 'Sınavı Sıfırla?',
            text: `${name} isimli öğrencinin sonucunu sileceksiniz. Öğrenci bu sınava TEKRAR girebilir. Emin misiniz?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#e17055',
            confirmButtonText: 'Evet, Sıfırla!',
            cancelButtonText: 'İptal'
        }).then((result) => {
            if (result.isConfirmed) {
                ajaxRequest("/Results/" + id, "DELETE", null, function(res) {
                    Swal.fire('Sıfırlandı!', res.message, 'success');
                    loadResults();
                });
            }
        });
    }

    // Admin Authority: Score Intervention (Fix incorrect scores)
    window.updateScore = function(id, currentScore) {
        Swal.fire({
            title: 'Puanı Güncelle',
            input: 'number',
            inputValue: currentScore,
            inputAttributes: { min: 0, max: 1000, step: 1 },
            showCancelButton: true,
            confirmButtonText: 'Güncelle',
            confirmButtonColor: '#6c5ce7',
        }).then((result) => {
            if (result.isConfirmed) {
                let newScore = parseInt(result.value);
                ajaxRequest("/Results/" + id + "/score", "PUT", { newScore: newScore }, function(res) {
                    Swal.fire('Başarılı', res.message, 'success');
                    loadResults();
                });
            }
        });
    }
</script>
}
