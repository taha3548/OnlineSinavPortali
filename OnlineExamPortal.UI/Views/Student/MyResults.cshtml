@{
    Layout = "_GenelLayout";
    ViewData["Title"] = "Karne / Sonuçlar";

}

<div class="row pt-4 justify-content-center">
    <div class="col-md-9 text-center">
        <div class="glass-card mb-4" style="border: 2px solid rgba(108, 92, 231, 0.2);">
            <i class="fa-solid fa-medal fa-5x text-warning mb-4" style="filter: drop-shadow(0 10px 10px rgba(253, 203, 110, 0.4));"></i>
            <h2 class="fw-bold" style="color: var(--primary-color);">Başarı Raporu</h2>
            <p class="lead fw-bold text-secondary mb-4">Katıldığınız sınavların sonuçları bu ekranda listelenmektedir.</p>
            
            <div id="resultsArea" class="bg-light rounded-4 p-4 border border-warning shadow-sm" style="border-style: dashed !important; min-height: 150px;">
                <h4 class="text-muted fw-bold mt-4"><i class="fa-solid fa-hourglass-half fa-spin me-2 text-warning"></i> Sınav Geçmişiniz Bekleniyor...</h4>

            </div>

            <a href="/Home/Index" class="btn-modern mt-4 d-inline-block px-5 shadow"><i class="fa-solid fa-arrow-left me-2"></i> Aktif Sınavlara Dön</a>

        </div>
    </div>
</div>

<!-- Ekran dışı: Türkçe metin tarayıcı fontu ile çizilir, PDF'e görüntü olarak aktarılır (jsPDF Helvetica Türkçe desteklemez) -->
<div id="certificatePdfSource" aria-hidden="true" style="position:fixed;left:-15000px;top:0;width:1123px;height:794px;background:#fcfbf6;box-sizing:border-box;font-family:'Nunito','Segoe UI',Tahoma,sans-serif;color:#2c3e50;">
    <div style="box-sizing:border-box;width:100%;height:100%;border:4px solid #daa520;outline:1px solid #2c3e50;outline-offset:-9px;padding:48px 56px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;">
        <h1 style="margin:0 0 16px;font-size:46px;font-weight:800;letter-spacing:1px;">BAŞARI SERTİFİKASI</h1>
        <p id="certIntro" style="margin:0 0 28px;font-size:17px;font-weight:600;max-width:900px;line-height:1.5;">Bu sertifika, aşağıda adı geçen öğrenciye gösterdiği üstün başarıdan dolayı verilmiştir:</p>
        <p id="certStudentName" style="margin:0 0 24px;font-size:38px;font-weight:800;font-style:italic;color:#daa520;line-height:1.2;"></p>
        <p id="certExamLine" style="margin:0 0 12px;font-size:18px;font-weight:600;max-width:920px;line-height:1.45;"></p>
        <p id="certScoreLine" style="margin:0 0 12px;font-size:26px;font-weight:800;"></p>
        <p id="certTail" style="margin:0 0 40px;font-size:18px;font-weight:600;">almaya hak kazanmıştır.</p>
        <div style="display:flex;width:100%;justify-content:space-between;max-width:820px;margin-top:8px;">
            <div style="text-align:center;flex:1;">
                <p style="margin:0;font-size:14px;font-weight:800;">TARİH</p>
                <div style="height:1px;width:120px;background:#daa520;margin:8px auto;"></div>
                <p id="certDateVal" style="margin:0;font-size:15px;font-weight:600;"></p>
            </div>
            <div style="text-align:center;flex:1;">
                <p style="margin:0;font-size:14px;font-weight:800;">ONLINE SINAV PORTALI</p>
                <div style="height:1px;width:160px;background:#daa520;margin:8px auto;"></div>
                <p style="margin:0;font-size:14px;font-style:italic;">Sistem Yöneticisi</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script>
        function escAttr(v) {
            return String(v == null ? "" : v)
                .replace(/&/g, "&amp;")
                .replace(/"/g, "&quot;")
                .replace(/</g, "&lt;");
        }

        function certDisplayName(raw) {
            var s = raw == null ? "" : String(raw).trim();
            if (!s || s.toLowerCase() === "undefined") {
                var u = typeof getUser === "function" ? getUser() : null;
                if (u && u.name) return u.name;
                return "Öğrenci";
            }
            return s;
        }

        function certDisplayExam(raw) {
            var s = raw == null ? "" : String(raw).trim();
            if (!s || s.toLowerCase() === "undefined") return "Sınav";
            return s;
        }

        $(document).ready(function() {
            var user = getUser();
            if (!user || (!user.userId && user.role !== 'Student')) {
                 $("#resultsArea").html(`<h4 class="text-danger fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i>Lütfen önce giriş yapın!</h4>`);
                 return;
            }

            var studentName = user.name || "Öğrenci";

            ajaxRequest("/Results/user/" + user.userId, "GET", null, function(results) {
                if (results.length === 0) {
                    $("#resultsArea").html(`<h4 class="text-muted fw-bold mt-4"><i class="fa-solid fa-box-open me-2 text-secondary"></i> Henüz herhangi bir sınava katılmadınız.</h4>`);

                } else {
                    let tableHtml = `
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 bg-white" style="border-radius: 15px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
                            <thead style="background-color: var(--primary-color);">
                                <tr>
                                    <th class="text-white py-3">Sınav Adı</th>
                                    <th class="text-white py-3">Puan</th>
                                    <th class="text-white py-3">D/Y</th>
                                    <th class="text-white py-3">Tarih</th>
                                    <th class="text-white py-3 text-end pe-4">Sertifika</th>
                                </tr>
                            </thead>
                            <tbody>
                    `;

                    $.each(results.reverse(), function(i, s) {
                        let examTitle = s.exam ? s.exam.title : "<span class='text-danger'>Silinmiş Sınav</span>";
                        let cleanTitle = s.exam ? s.exam.title : "Silinmiş Sınav";
                        let passingScore = s.exam ? (s.exam.passingScore || 60) : 60;
                        let scoreColor = s.score >= passingScore ? "text-success" : "text-danger";
                        let date = new Date(s.participationDate).toLocaleDateString('tr-TR', { day: '2-digit', month: 'long', year: 'numeric' });

                        let certificateBtn = s.score >= passingScore
                            ? `<button type="button" class="btn btn-sm btn-outline-success fw-bold rounded-pill shadow-sm btn-download-cert"
                                data-cert-name="${escAttr(studentName)}"
                                data-cert-exam="${escAttr(cleanTitle)}"
                                data-cert-score="${escAttr(String(s.score))}"
                                data-cert-date="${escAttr(date)}">
                                <i class="fa-solid fa-award me-1"></i> İndir</button>`
                            : `<span class="badge bg-light text-muted border border-secondary">Yetersiz Puan</span>`;

                        tableHtml += `
                                <tr>
                                    <td class="fw-bold text-dark fs-5 text-start ps-4"><i class="fa-solid fa-file-signature text-secondary me-2"></i>${examTitle}</td>
                                    <td><span class="fs-4 fw-bold ${scoreColor}">${s.score} Puan</span></td>
                                    <td>
                                        <span class="badge bg-success bg-opacity-75 text-white rounded-pill px-2 me-1">${s.correctCount} D</span>
                                        <span class="badge bg-danger bg-opacity-75 text-white rounded-pill px-2">${s.wrongCount} Y</span>
                                    </td>
                                    <td class="text-muted fw-bold">${date}</td>
                                    <td class="text-end pe-4">${certificateBtn}</td>
                                </tr>
                        `;
                    });

                    tableHtml += `</tbody></table></div>`;
                    $("#resultsArea").html(tableHtml);
                    $("#resultsArea").removeClass('border-warning').css("border-style", "solid").css("background", "transparent");
                }
            }, function(err) {
                 $("#resultsArea").html(`<h4 class="text-danger fw-bold mt-4"><i class="fa-solid fa-plug-circle-xmark me-2"></i>Karneniz getirilirken bir hata oluştu.</h4>`);

            });
        });

        $(document).on("click", ".btn-download-cert", function() {
            var $b = $(this);
            downloadCertificate(
                $b.attr("data-cert-name"),
                $b.attr("data-cert-exam"),
                $b.attr("data-cert-score"),
                $b.attr("data-cert-date")
            );
        });

        function downloadCertificate(name, exam, score, date) {
            var displayName = certDisplayName(name);
            var displayExam = certDisplayExam(exam);
            var scoreStr = (score == null || String(score).toLowerCase() === "undefined") ? "—" : String(score);
            var dateStr = (date == null || String(date).toLowerCase() === "undefined") ? new Date().toLocaleDateString("tr-TR", { day: "2-digit", month: "long", year: "numeric" }) : String(date);

            $("#certStudentName").text(displayName.toLocaleUpperCase("tr-TR"));
            $("#certExamLine").text("\u201C" + displayExam + "\u201D sınavını başarıyla tamamlayarak");
            $("#certScoreLine").text("TAM " + scoreStr + " PUAN");
            $("#certDateVal").text(dateStr);

            var el = document.getElementById("certificatePdfSource");
            html2canvas(el, {
                scale: 2,
                useCORS: true,
                backgroundColor: "#fcfbf6",
                logging: false
            }).then(function(canvas) {
                var imgData = canvas.toDataURL("image/png");
                var pdfW = 297;
                var pdfH = 210;
                var { jsPDF } = window.jspdf;
                var doc = new jsPDF({ orientation: "landscape", unit: "mm", format: "a4", compress: true });
                doc.addImage(imgData, "PNG", 0, 0, pdfW, pdfH, undefined, "FAST");
                var fileBase = displayName.replace(/[\\/:*?"<>|]+/g, "").replace(/\s+/g, "_").trim();
                if (!fileBase) fileBase = "Ogrenci";
                if (fileBase.length > 60) fileBase = fileBase.substring(0, 60);
                doc.save("Sertifika_" + fileBase + ".pdf");
                Swal.fire({ title: "Tebrikler!", text: "Sertifikanız başarıyla indirildi.", icon: "success" });
            }).catch(function() {
                Swal.fire({ title: "Hata", text: "Sertifika oluşturulamadı. Sayfayı yenileyip tekrar deneyin.", icon: "error" });
            });
        }
    </script>
}
